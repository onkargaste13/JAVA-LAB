
public class BankAccount {

    private double balance;

    public BankAccount(double balance) {
        this.balance = balance;
    }

    public void balanceEnquiry() {
        System.out.println("Current Balance: ₹" + balance);
    }

    public void deposit(double amount) throws NegativeNumberException {
        if (amount < 0) {
            throw new NegativeNumberException("Cannot deposit negative amount!");
        }
        balance += amount;
        System.out.println("Deposited: ₹" + amount);
    }

    public void withdraw(double amount)
            throws LowBalanceException, NegativeNumberException {

        if (amount < 0) {
            throw new NegativeNumberException("Cannot withdraw negative amount!");
        }

        if (amount > balance) {
            throw new LowBalanceException("Insufficient balance!");
        }

        balance -= amount;
        System.out.println("Withdrawn: ₹" + amount);
    }
}
2)public class NumberCheck {

    public static void checkNumber(int number) throws OddNumberException {

        if (number % 2 != 0) {
            throw new OddNumberException("Number is odd!");
        } else {
            System.out.println("Number is even.");
        }
    }
}
3) import ExceptionHandlingDemo.Calculator;
import ExceptionHandlingDemo.DivisionException;

public class MainProgram {

    public static void main(String[] args) {

        // -------- Q1: BankAccount Demo --------
        BankAccount account = new BankAccount(5000);

        try {
            account.balanceEnquiry();
            account.deposit(2000);
            account.withdraw(3000);
            account.withdraw(10000);  // LowBalanceException
        } catch (LowBalanceException | NegativeNumberException e) {
            System.out.println("Bank Error: " + e.getMessage());
        }

        System.out.println("--------------------------------");

        // -------- Q2: OddNumberException Demo --------
        try {
            NumberCheck.checkNumber(7);  // Change value to test
        } catch (OddNumberException e) {
            System.out.println("OddNumber Error: " + e.getMessage());
        }

        System.out.println("--------------------------------");

        // -------- Q3: DivisionException Demo --------
        Calculator calc = new Calculator();

        try {
            int result = calc.divide(10, 0);  // Change value to test
            System.out.println("Division Result: " + result);
        } catch (DivisionException e) {
            System.out.println("Division Error: " + e.getMessage());
        }

        System.out.println("--------------------------------");
        System.out.println("Program executed successfully.");
    }
}
