
1) Employee
class Employee {
    String firstName, lastName;
    double salary;

    Employee(String f, String l, double s) {
        firstName = f;
        lastName = l;
        salary = (s > 0) ? s : 0;
    }

    double yearlySalary() {
        return salary * 12;
    }

    public static void main(String[] args) {
        Employee e1 = new Employee("Sid", "Deshmukh", 30000);
        Employee e2 = new Employee("Rahul", "Patil", 25000);

        System.out.println(e1.yearlySalary());
        System.out.println(e2.yearlySalary());

        e1.salary *= 1.10;
        e2.salary *= 1.10;

        System.out.println(e1.yearlySalary());
        System.out.println(e2.yearlySalary());
    }
}
2)Area of Rectangle =
import java.util.Scanner;

class Area {
    int l, b;

    void setDim(int x, int y) {
        l = x;
        b = y;
    }

    int getArea() {
        return l * b;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Area a = new Area();

        a.setDim(sc.nextInt(), sc.nextInt());
        System.out.println(a.getArea());
    }
}
